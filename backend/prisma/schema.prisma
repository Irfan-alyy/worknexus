generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique @db.VarChar(255)
  password  String     @db.VarChar(255)
  role      Role       @default(employee)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  employee  Employee?
  messages  Message[]
  reactions Reaction[]
  createdChannels Channel[]      @relation("ChannelCreator")
  channelMemberships ChannelMember[]

  @@map("users")
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  createdAt DateTime   @default(now()) @map("created_at")
  employees Employee[]

  @@map("departments")
}

model Employee {
  id              Int           @id @default(autoincrement())
  userId          Int           @unique @map("user_id")
  departmentId    Int?          @map("department_id")
  firstName       String        @map("first_name") @db.VarChar(100)
  lastName        String        @map("last_name") @db.VarChar(100)
  paymentModel    PaymentModel  @default(fixed) @map("payment_model")
  baseSalary      Decimal?      @map("base_salary") @db.Decimal(10, 2)
  hourlyRate      Decimal?      @map("hourly_rate") @db.Decimal(10, 2)
  revenueSharePercent Decimal?  @map("revenue_share_percent") @db.Decimal(5, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  department      Department?   @relation(fields: [departmentId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payrolls        Payroll[]
  teamMemberships ProjectTeam[]
  managedProjects  Project[]
  tasks           Task[]
  timeLogs        TimeLog[]

  @@map("employees")
}

model Client {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  email     String    @unique @db.VarChar(255)
  company   String?   @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")
  projects  Project[]

  @@map("clients")
}

model Project {
  id          String        @id @default(uuid())
  clientId    Int           @map("client_id")
  managerEmployeeId Int?   @map("manager_employee_id")
  name        String        @db.VarChar(255)
  description String?
  status      ProjectStatus @default(pending)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  teamMembers ProjectTeam[]
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  manager     Employee?     @relation(fields: [managerEmployeeId], references: [id], onDelete: SetNull)
  tasks       Task[]
  channels    Channel[]

  @@map("projects")
}

model ProjectTeam {
  projectId  String   @map("project_id")
  employeeId Int      @map("employee_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, employeeId])
  @@map("project_teams")
}

model Task {
  id          String       @id @default(uuid())
  projectId   String       @map("project_id")
  employeeId  Int?         @map("employee_id")
  title       String       @db.VarChar(255)
  description String?
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(pending)
  completedAt DateTime?    @map("completed_at")
  dueDate     DateTime?    @map("due_date")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  employee    Employee?    @relation(fields: [employeeId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeLogs    TimeLog[]

  @@map("tasks")
}

model TimeLog {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  employeeId  Int      @map("employee_id")
  hours       Decimal  @db.Decimal(5, 2)
  description String?
  loggedAt    DateTime @default(now()) @map("logged_at")
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("time_logs")
}

model Payroll {
  id             String        @id @default(uuid())
  employeeId     Int           @map("employee_id")
  amount         Decimal       @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(pending) @map("payment_status")
  payPeriodStart DateTime      @map("pay_period_start")
  payPeriodEnd   DateTime      @map("pay_period_end")
  processedAt    DateTime?     @map("processed_at")
  breakdown      Json?         @map("breakdown")
  createdAt      DateTime      @default(now()) @map("created_at")
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, payPeriodStart, payPeriodEnd], map: "payroll_employee_period_key")
  @@map("payroll")
}

model Channel {
  id              String          @id @default(uuid())
  name            String          @db.VarChar(100)
  description     String?
  projectId       String?         @map("project_id")
  isPrivate       Boolean         @default(false) @map("is_private")
  createdByUserId Int             @map("created_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("ChannelCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  messages        Message[]
  members         ChannelMember[]

  @@unique([projectId, name], map: "channel_project_name_key")
  @@index([projectId], map: "idx_channel_project")
  @@index([createdByUserId], map: "idx_channel_created_by")

  @@map("channels")
}

model ChannelMember {
  channelId String   @map("channel_id")
  userId    Int      @map("user_id")
  addedAt   DateTime @default(now()) @map("added_at")
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId], map: "idx_channel_member_user")
  @@map("channel_members")
}

model Message {
  id        String     @id @default(uuid())
  channelId String     @map("channel_id")
  userId    Int        @map("user_id")
  content   String
  parentId  String?    @map("parent_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parent    Message?   @relation("ThreadReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Message[]  @relation("ThreadReplies")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]

  @@index([parentId], map: "idx_message_parent")
  @@map("messages")
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    Int      @map("user_id")
  emoji     String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("reactions")
}

enum Role {
  admin
  hr
  pm
  employee
}

enum PaymentModel {
  fixed
  hourly
  revenue_share
}

enum ProjectStatus {
  pending
  active
  completed
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum TaskStatus {
  pending
  in_progress
  completed
  blocked
}

enum PaymentStatus {
  pending
  processed
  paid
}
